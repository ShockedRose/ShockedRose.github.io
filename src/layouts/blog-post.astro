---
import Layout from "@/layouts/main.astro";
import { Badge } from "@/components/ui/badge";
import Footer from "@/components/footer.astro";

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: Date;
    tags: string[];
  };
}

const { frontmatter } = Astro.props;

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Layout
  title={`${frontmatter.title} — Miguel Rosa`}
  description={frontmatter.description}
  currentPage="blog"
>
  <article class="pt-32 pb-20">
    <div class="mx-auto max-w-3xl px-6 lg:px-0">
      <a
        href="/blog"
        class="mb-12 inline-flex items-center gap-2 font-mono text-xs tracking-wide text-muted-foreground transition-colors hover:text-primary"
      >
        <svg
          class="size-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M19 12H5M12 19l-7-7 7-7"></path>
        </svg>
        Back to Blog
      </a>

      <div class="mb-6 flex items-center gap-4">
        <time class="font-mono text-xs tracking-wide text-muted-foreground">
          {formatDate(frontmatter.date)}
        </time>
      </div>

      <h1
        class="mb-6 font-display text-4xl leading-[1.1] text-foreground lg:text-5xl"
      >
        {frontmatter.title}
      </h1>

      <p class="mb-8 text-lg leading-relaxed text-muted-foreground">
        {frontmatter.description}
      </p>

      <div class="mb-12 flex flex-wrap gap-2">
        {
          frontmatter.tags.map((tag) => (
            <Badge
              variant="secondary"
              className="font-mono text-[10px] tracking-wider px-2.5 py-1"
            >
              {tag}
            </Badge>
          ))
        }
      </div>

      <div class="mb-12 h-px bg-border"></div>

      <div class="prose">
        <slot />
      </div>
    </div>
  </article>

  <Footer />
</Layout>
