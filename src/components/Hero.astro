<section class="relative flex min-h-screen items-center overflow-hidden">
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image: linear-gradient(to right, oklch(0.6 0.17 152) 1px, transparent 1px), linear-gradient(to bottom, oklch(0.6 0.17 152) 1px, transparent 1px); background-size: 80px 80px;"
  >
  </div>

  <div class="relative mx-auto w-full max-w-7xl px-6 pt-32 pb-20 lg:px-16">
    <div class="mb-16 flex items-center gap-4 animate-fade-in" data-delay="1">
      <span class="font-mono text-xs tracking-[0.25em] text-primary">01</span>
      <div class="h-px w-12 bg-accent-green/60 animate-expand" data-delay="2"></div>
      <span
        class="font-mono text-xs tracking-[0.25em] uppercase text-muted-foreground"
        >Introduction</span
      >
    </div>

    <h1 class="font-display leading-[0.85] tracking-tight">
      <span
        class="block text-[clamp(3.5rem,11vw,11rem)] text-foreground animate-fade-up"
        data-delay="2">Miguel</span
      >
      <span
        class="ml-[5vw] block text-[clamp(3.5rem,11vw,11rem)] text-primary italic animate-fade-up"
        data-delay="3">Rosa</span
      >
    </h1>

    <div
      class="mt-12 flex flex-col gap-8 lg:mt-16 lg:flex-row lg:items-end lg:justify-between"
    >
      <div class="max-w-md animate-fade-up" data-delay="5">
        <p
          class="mb-4 font-mono text-xs tracking-[0.25em] uppercase text-primary"
        >
          Web Developer & Digital Craftsman
        </p>
        <p class="leading-relaxed text-muted-foreground">
          Crafting thoughtful, performant web experiences with modern
          technologies. Focused on clean code, creative solutions, and
          interfaces that feel alive.
        </p>
      </div>

      <div class="flex flex-wrap gap-4 animate-fade-up" data-delay="6">
        <a
          href="#projects"
          class="group inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-medium text-primary-foreground transition-all hover:bg-primary/90"
        >
          View Work
          <svg
            class="size-4 transition-transform group-hover:translate-x-1"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </a>
        <a
          href="#contact"
          class="inline-flex items-center gap-2 rounded-lg border border-border bg-transparent px-6 py-3 text-sm font-medium text-foreground transition-all hover:bg-accent hover:text-accent-foreground"
        >
          Get in Touch
        </a>
      </div>
    </div>
  </div>

  <div
    class="absolute bottom-8 left-1/2 flex -translate-x-1/2 flex-col items-center gap-3 animate-fade-in"
    data-delay="8"
  >
    <span
      class="font-mono text-[10px] tracking-[0.3em] uppercase text-muted-foreground"
      >Scroll</span
    >
    <div class="h-10 w-px bg-gradient-to-b from-accent-green/60 to-transparent">
    </div>
  </div>
</section>
