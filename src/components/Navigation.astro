---
interface Props {
  currentPage?: string;
}

const { currentPage = "home" } = Astro.props;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-40 transition-all duration-300">
  <div class="mx-auto max-w-7xl px-6 lg:px-16">
    <nav class="flex h-20 items-center justify-between border-b border-border/30">
      <a
        href="/"
        class="font-display text-xl tracking-tight text-foreground transition-colors hover:text-primary"
      >
        Miguel<span class="text-primary italic"> Rosa</span>
      </a>

      <div class="hidden items-center gap-8 md:flex">
        <a
          href="/#about"
          class="font-mono text-xs tracking-[0.2em] uppercase text-muted-foreground transition-colors hover:text-primary"
          >About</a
        >
        <a
          href="/#projects"
          class="font-mono text-xs tracking-[0.2em] uppercase text-muted-foreground transition-colors hover:text-primary"
          >Work</a
        >
        <a
          href="/blog"
          class:list={[
            "font-mono text-xs tracking-[0.2em] uppercase transition-colors hover:text-primary",
            currentPage === "blog" ? "text-primary" : "text-muted-foreground",
          ]}
          >Blog</a
        >
        <a
          href="/#contact"
          class="font-mono text-xs tracking-[0.2em] uppercase text-muted-foreground transition-colors hover:text-primary"
          >Contact</a
        >
      </div>

      <button
        id="mobile-menu-btn"
        class="relative flex size-10 items-center justify-center text-foreground md:hidden"
        aria-label="Toggle navigation"
      >
        <svg
          class="hamburger-icon size-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        >
          <line x1="4" y1="7" x2="20" y2="7"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="17" x2="20" y2="17"></line>
        </svg>
        <svg
          class="close-icon hidden size-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        >
          <line x1="6" y1="6" x2="18" y2="18"></line>
          <line x1="6" y1="18" x2="18" y2="6"></line>
        </svg>
      </button>
    </nav>
  </div>

  <div
    id="mobile-menu"
    class="fixed inset-0 top-20 z-30 translate-x-full bg-background/98 backdrop-blur-xl transition-transform duration-300 ease-out md:hidden"
  >
    <nav class="flex flex-col items-start gap-2 px-6 py-10">
      <a
        href="/#about"
        class="mobile-nav-link py-3 font-display text-4xl text-foreground transition-colors hover:text-primary"
        >About</a
      >
      <a
        href="/#projects"
        class="mobile-nav-link py-3 font-display text-4xl text-foreground transition-colors hover:text-primary"
        >Projects</a
      >
      <a
        href="/blog"
        class="mobile-nav-link py-3 font-display text-4xl text-foreground transition-colors hover:text-primary"
        >Blog</a
      >
      <a
        href="/#contact"
        class="mobile-nav-link py-3 font-display text-4xl text-foreground transition-colors hover:text-primary"
        >Contact</a
      >

      <div class="mt-8 flex gap-5 border-t border-border pt-8">
        <a
          href="https://github.com"
          target="_blank"
          rel="noopener"
          class="text-muted-foreground transition-colors hover:text-primary"
          aria-label="GitHub"
        >
          <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
            ></path>
          </svg>
        </a>
        <a
          href="https://linkedin.com"
          target="_blank"
          rel="noopener"
          class="text-muted-foreground transition-colors hover:text-primary"
          aria-label="LinkedIn"
        >
          <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
        </a>
        <a
          href="https://twitter.com"
          target="_blank"
          rel="noopener"
          class="text-muted-foreground transition-colors hover:text-primary"
          aria-label="X / Twitter"
        >
          <svg class="size-5" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
            ></path>
          </svg>
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const header = document.getElementById("site-header");
  const hamburger = btn?.querySelector(".hamburger-icon");
  const closeIcon = btn?.querySelector(".close-icon");

  let isOpen = false;

  function toggleMenu() {
    isOpen = !isOpen;
    menu?.classList.toggle("translate-x-full", !isOpen);
    menu?.classList.toggle("translate-x-0", isOpen);
    hamburger?.classList.toggle("hidden", isOpen);
    closeIcon?.classList.toggle("hidden", !isOpen);
    document.body.style.overflow = isOpen ? "hidden" : "";
  }

  btn?.addEventListener("click", toggleMenu);

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      if (isOpen) toggleMenu();
    });
  });

  window.addEventListener("scroll", () => {
    const scrolled = window.scrollY > 50;
    header?.classList.toggle("bg-background/80", scrolled);
    header?.classList.toggle("backdrop-blur-xl", scrolled);
  });
</script>
