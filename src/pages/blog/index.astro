---
import Layout from "@/layouts/main.astro";
import Footer from "@/components/Footer.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { Badge } from "@/components/ui/badge";

type BlogPost = CollectionEntry<"blog">;

const posts: BlogPost[] = (await getCollection("blog"))
  .filter((post: BlogPost) => !post.data.draft)
  .sort((a: BlogPost, b: BlogPost) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<Layout
  title="Blog — Miguel Rosa"
  description="Thoughts and explorations on web development, design, and technology."
  currentPage="blog"
>
  <section class="pt-32 pb-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-16">
      <div class="mb-16 flex items-center gap-4">
        <span class="font-mono text-xs tracking-[0.25em] text-primary"
          >Blog</span
        >
        <div class="h-px w-12 bg-accent-green/60"></div>
      </div>

      <h1 class="mb-4 font-display text-5xl text-foreground lg:text-7xl">
        Thoughts & <span class="text-primary italic">Explorations</span>
      </h1>
      <p class="mb-16 max-w-lg leading-relaxed text-muted-foreground">
        Writing about web development, design patterns, and the tools that make
        building for the web a joy.
      </p>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group flex flex-col gap-4 rounded-xl border border-border bg-card/50 p-8 transition-all duration-300 hover:border-primary/30 hover:bg-card"
              data-animate
            >
              <time class="font-mono text-xs tracking-wide text-muted-foreground">
                {formatDate(post.data.date)}
              </time>

              <h2 class="font-display text-xl text-foreground transition-colors group-hover:text-primary lg:text-2xl">
                {post.data.title}
              </h2>

              <p class="line-clamp-3 text-sm leading-relaxed text-muted-foreground">
                {post.data.description}
              </p>

              <div class="flex flex-wrap gap-1.5 pt-1">
                {post.data.tags.map((tag: string) => (
                  <Badge
                    variant="secondary"
                    className="font-mono text-[10px] tracking-wider px-2 py-0.5"
                  >
                    {tag}
                  </Badge>
                ))}
              </div>

              <span class="mt-auto inline-flex items-center gap-1.5 pt-2 font-mono text-xs text-primary">
                Read Article
                <svg
                  class="size-3.5 transition-transform group-hover:translate-x-1"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <Footer />
</Layout>
